FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# sqlite | mariadb
DB_TYPE=sqlite
DATABASE_TYPE=sqlite
SQLITE_PATH=data/ops.db

# MariaDB (future)
# MARIADB_HOST=localhost
# MARIADB_PORT=3306
# MARIADB_USER=ops
# MARIADB_PASSWORD=
# MARIADB_DATABASE=ops

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LLM_PROVIDER=mock
LLM_API_KEY=
KAFKA_TOPIC=ops-events
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=0
DOCS_DIR=data/docs

LOG_LEVEL=INFO

# Keras model (mykafkakeras — no copy required)
KERAS_ENABLED=1
MYKAFKAKERAS_DIR=../mykafkakeras
KERAS_MODEL_PATH=../mykafkakeras/models/case.1/event_type_v1.keras
KERAS_CLASS_MAP_PATH=../mykafkakeras/models/case.1/class_map.json

# Hugging Face klue/bert-base (Colab phase2 산출물)
# auto = HF 우선, 없으면 Keras, 둘 다 없으면 rule-based
INFERENCE_BACKEND=auto
HF_ENABLED=1
HF_MODEL_DIR=../mykafkakeras/models/case.2/hf-klue-bert-v1
HF_MAX_LENGTH=128
