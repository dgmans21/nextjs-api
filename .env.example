FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# sqlite | mariadb
DB_TYPE=sqlite
DATABASE_TYPE=sqlite
SQLITE_PATH=data/ops.db

# MariaDB (future)
# MARIADB_HOST=localhost
# MARIADB_PORT=3306
# MARIADB_USER=ops
# MARIADB_PASSWORD=
# MARIADB_DATABASE=ops

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LLM_PROVIDER=mock
LLM_API_KEY=
KAFKA_TOPIC=ops-events
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=0
DOCS_DIR=data/docs

LOG_LEVEL=INFO
